---
import { whyNotHire } from '../data/content';
---

<section class="section container">
  <div class="why-grid">
    <div class="reveal">
      <span class="eyebrow">{whyNotHire.eyebrow}</span>
      <h2 class="section-title">{whyNotHire.title}</h2>
      <div class="why-copy">
        {whyNotHire.paragraphs.map((p) => <p>{p}</p>)}
        <blockquote>{whyNotHire.quote}</blockquote>
      </div>
    </div>

    <div class="math-card reveal" style="--reveal-delay: 0.15s">
      <h3>The real math</h3>
      <div class="math-rows">
        {
          whyNotHire.rows.map((row) => (
            <div class="math-row">
              <span>{row.label}</span>
              <strong>{row.value}</strong>
            </div>
          ))
        }
        <div class="math-row highlight">
          <span>{whyNotHire.highlight.label}</span>
          <strong>{whyNotHire.highlight.value}</strong>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .why-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }

  .why-copy {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    color: var(--text-dim);
  }

  blockquote {
    margin: 0.75rem 0 0;
    padding-left: 1.1rem;
    border-left: 2px solid var(--sage);
    color: var(--text);
    font-style: italic;
  }

  .math-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: clamp(1.5rem, 3vw, 2.25rem);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
  }

  .math-card h3 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--teal-bright);
    margin-bottom: 1.25rem;
  }

  .math-rows {
    display: flex;
    flex-direction: column;
  }

  .math-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.9rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.95rem;
  }

  .math-row span {
    color: var(--text-dim);
  }

  .math-row strong {
    color: var(--cream);
    font-weight: 600;
    text-align: right;
  }

  .math-row.highlight {
    border-bottom: none;
    padding-top: 1.1rem;
  }

  .math-row.highlight span {
    color: var(--sage);
    font-weight: 600;
  }

  .math-row.highlight strong {
    color: var(--sage);
  }

  @media (max-width: 860px) {
    .why-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import { finalCta, links } from '../data/content';
---

<section class="section container">
  <div class="cta-card reveal">
    <span class="cta-badge">
      <span class="pulse-dot" aria-hidden="true"></span>
      {finalCta.badge}
    </span>
    <h2>{finalCta.title}</h2>
    <p>{finalCta.lead}</p>
    <a class="btn btn-primary cta-btn" href={links.calendly} target="_blank" rel="noopener">
      {finalCta.cta} →
    </a>
    <small>{finalCta.microcopy}</small>
  </div>
</section>

<style>
  .cta-card {
    position: relative;
    text-align: center;
    background:
      radial-gradient(ellipse 70% 90% at 50% -20%, rgba(97, 135, 138, 0.18), transparent 60%),
      var(--bg-card);
    border: 1px solid var(--border-bright);
    border-radius: var(--radius-lg);
    padding: clamp(2.5rem, 6vw, 4.5rem) clamp(1.5rem, 5vw, 4rem);
    overflow: hidden;
  }

  .cta-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--sage);
    border: 1px solid rgba(156, 178, 146, 0.35);
    background: rgba(156, 178, 146, 0.08);
    padding: 0.4rem 1rem;
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }

  .pulse-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--sage);
    animation: pulse 2s ease-out infinite;
  }

  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(156, 178, 146, 0.5);
    }
    70% {
      box-shadow: 0 0 0 9px rgba(156, 178, 146, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(156, 178, 146, 0);
    }
  }

  .cta-card h2 {
    font-size: clamp(1.9rem, 4.5vw, 3rem);
    margin-bottom: 1rem;
  }

  .cta-card p {
    color: var(--text-dim);
    font-size: 1.08rem;
    max-width: 34rem;
    margin: 0 auto 2rem;
  }

  .cta-btn {
    font-size: 1.02rem;
    padding: 1rem 2.2rem;
  }

  .cta-card small {
    display: block;
    margin-top: 1.25rem;
    color: var(--text-faint);
    font-size: 0.8rem;
  }
</style>

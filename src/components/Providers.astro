---
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import { providers } from '../data/content';

// Real brand marks from the devicon and simple-icons libraries (MIT licensed),
// bundled locally at build time — no external runtime requests.
function loadIcon(path: string) {
  const raw = readFileSync(resolve(process.cwd(), path), 'utf-8');
  const viewBox = raw.match(/viewBox="([^"]+)"/)?.[1] ?? '0 0 24 24';
  const inner = raw
    .replace(/^[\s\S]*?<svg[^>]*>/, '')
    .replace(/<\/svg>\s*$/, '')
    .replace(/fill="#[0-9a-fA-F]{3,8}"/g, 'fill="currentColor"');
  return { viewBox, inner };
}

const marks: Record<string, { viewBox: string; inner: string }> = {
  AWS: loadIcon('node_modules/devicon/icons/amazonwebservices/amazonwebservices-plain-wordmark.svg'),
  'Google Cloud': loadIcon('node_modules/devicon/icons/googlecloud/googlecloud-plain.svg'),
  Azure: loadIcon('node_modules/devicon/icons/azure/azure-plain.svg'),
  'Alibaba Cloud': loadIcon('node_modules/simple-icons/icons/alibabacloud.svg'),
  DigitalOcean: loadIcon('node_modules/devicon/icons/digitalocean/digitalocean-original.svg'),
  // Not a brand — a plain generic mark, drawn for this project.
  'On-Premise': {
    viewBox: '0 0 24 24',
    inner:
      '<path fill="currentColor" d="M4 4h16a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1Zm3.25 3.5a1.25 1.25 0 1 0 0 2.5 1.25 1.25 0 0 0 0-2.5ZM4 14h16a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1v-4a1 1 0 0 1 1-1Zm3.25 3.5a1.25 1.25 0 1 0 0 2.5 1.25 1.25 0 0 0 0-2.5Z"/>',
  },
};

const items = providers.items;
---

<section class="section providers" id="providers">
  <div class="container reveal">
    <span class="eyebrow">{providers.eyebrow}</span>
    <h2 class="section-title">{providers.title}</h2>
  </div>

  <div class="marquee reveal" style="--reveal-delay: 0.1s" aria-label="Supported providers" id="prov-marquee">
    <div class="marquee-track" id="prov-track">
      {
        [0, 1].map((dup) => (
          <div class="marquee-group" aria-hidden={dup === 1 ? 'true' : undefined}>
            {items.map((name) => (
              <span class="provider">
                <svg
                  viewBox={marks[name].viewBox}
                  width="26"
                  height="26"
                  fill="currentColor"
                  aria-hidden="true"
                  set:html={marks[name].inner}
                />
                {name}
              </span>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .providers {
    padding-bottom: 3rem;
  }

  .marquee {
    margin-top: 2.5rem;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
  }

  .marquee {
    touch-action: pan-y;
    cursor: grab;
  }

  .marquee.dragging {
    cursor: grabbing;
  }

  .marquee-track {
    display: flex;
    width: max-content;
    will-change: transform;
  }

  .marquee-group {
    display: flex;
    align-items: center;
    gap: clamp(2.5rem, 6vw, 5rem);
    padding-right: clamp(2.5rem, 6vw, 5rem);
  }

  .provider {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.15rem;
    color: var(--text-faint);
    white-space: nowrap;
    transition: color 0.3s;
    user-select: none;
    -webkit-user-select: none;
  }

  .provider:hover {
    color: var(--cream);
  }

  .provider svg {
    color: var(--teal);
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      flex-wrap: wrap;
      width: auto;
      justify-content: center;
    }

    .marquee-group[aria-hidden='true'] {
      display: none;
    }

    .marquee {
      mask-image: none;
      -webkit-mask-image: none;
    }
  }
</style>

<script>
  // Auto-scrolling marquee that also responds to wheel / trackpad / drag.
  const marquee = document.getElementById('prov-marquee');
  const track = document.getElementById('prov-track');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (marquee && track && !reduceMotion) {
    // Clone the first group until the track comfortably outruns the
    // viewport twice over, so the loop never visibly runs dry mid-scroll.
    const firstGroup = track.querySelector('.marquee-group') as HTMLElement;
    let groupWidth = firstGroup.getBoundingClientRect().width;
    while (track.scrollWidth < marquee.clientWidth * 2 + groupWidth) {
      const clone = firstGroup.cloneNode(true) as HTMLElement;
      clone.setAttribute('aria-hidden', 'true');
      track.appendChild(clone);
    }
    groupWidth = firstGroup.getBoundingClientRect().width;

    let offset = 0;
    let velocity = 0;
    const AUTO_SPEED = 0.035; // px per ms
    let dragging = false;
    let lastX = 0;
    let lastTime = performance.now();

    function halfWidth() {
      return groupWidth;
    }

    marquee.addEventListener(
      'wheel',
      (e) => {
        const delta = Math.abs(e.deltaX) > Math.abs(e.deltaY) ? e.deltaX : e.deltaY;
        velocity += delta * 0.02;
        e.preventDefault();
      },
      { passive: false }
    );

    marquee.addEventListener('pointerdown', (e) => {
      dragging = true;
      lastX = e.clientX;
      marquee!.classList.add('dragging');
      marquee!.setPointerCapture(e.pointerId);
    });
    marquee.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      offset -= e.clientX - lastX;
      lastX = e.clientX;
    });
    const endDrag = () => {
      dragging = false;
      marquee!.classList.remove('dragging');
    };
    marquee.addEventListener('pointerup', endDrag);
    marquee.addEventListener('pointercancel', endDrag);

    function tick(now: number) {
      const dt = Math.min(now - lastTime, 48);
      lastTime = now;

      if (!dragging) {
        offset += AUTO_SPEED * dt + velocity;
        velocity *= 0.92; // friction
        if (Math.abs(velocity) < 0.01) velocity = 0;
      }

      const w = halfWidth();
      if (w > 0) {
        const wrapped = ((offset % w) + w) % w;
        track!.style.transform = `translateX(${-wrapped}px)`;
      }
      requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
  }
</script>

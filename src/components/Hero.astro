---
import { hero, links } from '../data/content';
---

<section class="hero container" id="top">
  <div class="hero-inner">
    <span class="badge hero-in" style="--in-delay: 0s">{hero.badge}</span>
    <h1 class="hero-title hero-in" style="--in-delay: 0.08s">
      {hero.titleTop}<br />
      <span class="grad-text">{hero.titleAccent}</span>
    </h1>
    <p class="hero-lead hero-in" style="--in-delay: 0.16s">{hero.lead}</p>
    <div class="hero-ctas hero-in" style="--in-delay: 0.24s">
      <a class="btn btn-primary" href={links.calendly} target="_blank" rel="noopener">
        {hero.ctaPrimary}
      </a>
      <a class="btn btn-ghost" href="#how">{hero.ctaSecondary} →</a>
    </div>

    <div class="terminal hero-in" style="--in-delay: 0.36s" aria-hidden="true">
      <div class="terminal-bar">
        <span></span><span></span><span></span>
        <em>infrahats — production</em>
      </div>
      <pre class="terminal-body"><code id="term-code">$ </code><span class="caret"></span></pre>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(4rem, 10vw, 7.5rem) clamp(3rem, 6vw, 5rem);
    text-align: center;
  }

  .hero-inner {
    max-width: 52rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--teal-bright);
    border: 1px solid rgba(97, 135, 138, 0.35);
    background: rgba(97, 135, 138, 0.08);
    padding: 0.4rem 1rem;
    border-radius: 999px;
    margin-bottom: 1.75rem;
  }

  .hero-title {
    font-size: clamp(2.4rem, 6.5vw, 4.4rem);
    font-weight: 650;
    margin-bottom: 1.5rem;
  }

  .hero-lead {
    color: var(--text-dim);
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    max-width: 40rem;
    margin-bottom: 2.25rem;
  }

  .hero-ctas {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 3.5rem;
  }

  /* terminal ------------------------------------------------------------ */

  .terminal {
    width: min(34rem, 100%);
    border-radius: var(--radius);
    border: 1px solid var(--border-bright);
    background: rgba(13, 18, 24, 0.85);
    backdrop-filter: blur(6px);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
    text-align: left;
    overflow: hidden;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .terminal-bar span {
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 50%;
    background: var(--border-bright);
  }

  .terminal-bar span:nth-child(1) { background: #b06a5c; }
  .terminal-bar span:nth-child(2) { background: #c2a45f; }
  .terminal-bar span:nth-child(3) { background: var(--sage); }

  .terminal-bar em {
    margin-left: auto;
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-faint);
  }

  .terminal-body {
    margin: 0;
    padding: 1rem 1.15rem 1.15rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.7;
    color: var(--sage);
    min-height: 6.2rem;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .caret {
    display: inline-block;
    width: 0.5em;
    height: 1em;
    background: var(--sage);
    vertical-align: text-bottom;
    animation: blink 1.1s steps(1) infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  /* entrance ------------------------------------------------------------ */

  .hero-in {
    opacity: 0;
    transform: translateY(18px);
    animation: hero-in 0.9s var(--ease-out) forwards;
    animation-delay: var(--in-delay, 0s);
  }

  @keyframes hero-in {
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-in {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .caret {
      animation: none;
    }
  }
</style>

<script>
  const el = document.getElementById('term-code');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const SCRIPTS = [
    ['$ terraform apply -auto-approve', '  Apply complete! 42 added, 0 changed, 0 destroyed.'],
    ['$ kubectl get nodes', '  node-1   Ready    control-plane   99d\n  node-2   Ready    worker          99d'],
    ['$ helm upgrade platform ./charts --install', '  Release "platform" has been upgraded. Happy Helming!'],
    ['$ infrahats deploy --env production', '  ✓ Infrastructure healthy. SLO 99.99% — all green.'],
  ];

  if (el) {
    if (reduceMotion) {
      el.textContent = SCRIPTS[0].join('\n');
    } else {
      let script = 0;

      async function sleep(ms: number) {
        return new Promise((r) => setTimeout(r, ms));
      }

      async function typeLine(line: string, speed: number) {
        for (const ch of line) {
          el!.textContent += ch;
          await sleep(speed);
        }
      }

      async function run() {
        for (;;) {
          const [cmd, out] = SCRIPTS[script % SCRIPTS.length];
          el!.textContent = '';
          await typeLine(cmd, 34);
          await sleep(450);
          el!.textContent += '\n';
          await typeLine(out, 6);
          await sleep(2600);
          script++;
        }
      }

      run();
    }
  }
</script>

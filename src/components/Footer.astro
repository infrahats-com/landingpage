---
import { footer, links } from '../data/content';
import Logo from './Logo.astro';
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <Logo />
        <p>{footer.blurb}</p>
        <a class="footer-email" href={`mailto:${links.email}`}>{links.email}</a>
      </div>

      <nav aria-label="Footer">
        <p class="footer-heading">Explore</p>
        <ul>
          <li><a href="/services/">Services</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/pricing/">Pricing</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </nav>

      <div>
        <p class="footer-heading">Connect</p>
        <ul>
          <li><a href={links.calendly} target="_blank" rel="noopener">Book a call</a></li>
          <li><a href={links.linkedin} target="_blank" rel="noopener">LinkedIn</a></li>
          <li><a href={links.github} target="_blank" rel="noopener">GitHub</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>{footer.copyright}</p>
      <p class="footer-legal">
        <a href="/privacy/">Privacy</a>
        <span aria-hidden="true">·</span>
        <a href="/terms/">Terms</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background: rgba(8, 11, 14, 0.75);
    padding-block: 3.5rem 2rem;
    margin-top: 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 2.5rem;
    margin-bottom: 3rem;
  }

  .footer-brand :global(svg) {
    height: 1.8rem;
    width: auto;
    display: block;
    margin-bottom: 1rem;
  }

  .footer-brand p {
    font-size: 0.9rem;
    color: var(--text-dim);
    max-width: 20rem;
    margin-bottom: 0.9rem;
  }

  .footer-email {
    font-size: 0.88rem;
    color: var(--sage);
  }

  .footer-email:hover {
    color: var(--teal-bright);
  }

  .footer-heading {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--text-dim);
    margin-bottom: 1rem;
  }

  .footer ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer ul a {
    font-size: 0.9rem;
    color: var(--text-dim);
    transition: color 0.2s;
  }

  .footer ul a:hover {
    color: var(--cream);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
    font-size: 0.78rem;
    color: var(--text-dim);
  }

  .footer-legal {
    display: flex;
    gap: 0.5rem;
  }

  .footer-legal a {
    color: var(--text-dim);
    transition: color 0.2s;
  }

  .footer-legal a:hover {
    color: var(--cream);
  }

  @media (max-width: 720px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>

---
import '@fontsource-variable/outfit';
import '../styles/global.css';
import InfraBackground from '../components/InfraBackground.astro';
import { SEO } from 'astro-seo';
import { pricing } from '../data/content';

const title = 'infrahats — DevOps, SRE & Cloud Infrastructure On Demand';
const description =
  'Senior DevOps, SRE & Solutions Architects on demand. infrahats designs, deploys, and operates production-grade cloud infrastructure — AWS, GCP, Azure, Kubernetes.';
const url = 'https://infrahats.com/';
// The ?v= is a cache-buster for social scrapers (LinkedIn caches image
// fetch failures by exact URL). Bump it whenever og-image.png changes.
const ogImage = `${url}og-image.png?v=4`;
const ogImageAlt = 'infrahats — production-grade infrastructure, without the full-time hire';

const schema = {
  '@context': 'https://schema.org',
  // OnlineBusiness (an Organization subtype) fits a worldwide online-only
  // consultancy — LocalBusiness subtypes like ProfessionalService make
  // Google's tooling expect a physical address. priceRange is
  // LocalBusiness-only; the offers below carry the pricing instead.
  '@type': 'OnlineBusiness',
  name: 'infrahats',
  url,
  logo: `${url}logo.svg`,
  image: ogImage,
  email: 'hello@infrahats.com',
  description,
  areaServed: 'Worldwide',
  sameAs: [
    'https://www.linkedin.com/company/infrahats',
    'https://github.com/infrahats-com',
  ],
  knowsAbout: [
    'DevOps',
    'Site Reliability Engineering',
    'Kubernetes',
    'Terraform',
    'AWS',
    'GCP',
    'Azure',
    'AI Infrastructure',
    'Platform Engineering',
  ],
  makesOffer: pricing.tiers.map((t) => ({
    '@type': 'Offer',
    name: t.name,
    description: `${t.blurb}${t.features[0] ? ` ${t.features[0]}.` : ''}`,
    ...(t.price.startsWith('$')
      ? { price: t.price.replace(/[$,]/g, ''), priceCurrency: 'USD' }
      : {}),
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <SEO
      title={title}
      description={description}
      canonical={url}
      openGraph={{
        basic: {
          title,
          type: 'website',
          image: ogImage,
          url,
        },
        optional: {
          description,
          siteName: 'infrahats',
          locale: 'en_US',
        },
        image: {
          width: 4800,
          height: 2520,
          alt: ogImageAlt,
          type: 'image/png',
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title,
        description,
        image: ogImage,
        imageAlt: ogImageAlt,
      }}
      extend={{
        meta: [{ name: 'theme-color', content: '#0a0e12' }],
      }}
    />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Google tag (gtag.js) — Google Ads conversion tracking -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=AW-18304232789"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'AW-18304232789');

      // Booking happens on Calendly (external), so the conversion signal is
      // a click on any Calendly CTA. All of them open in a new tab, so the
      // event fires without racing page navigation.
      document.addEventListener('click', (e) => {
        if (e.target.closest && e.target.closest('a[href*="calendly.com"]')) {
          gtag('event', 'ads_conversion_Book_appointment_1', {});
        }
      });
    </script>
  </head>
  <body>
    <InfraBackground />
    <slot />
    <div class="cursor-ring" aria-hidden="true">
      <svg viewBox="0 0 40 40">
        <polygon
          points="20,3.5 34.3,11.75 34.3,28.25 20,36.5 5.7,28.25 5.7,11.75"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linejoin="round"></polygon>
      </svg>
    </div>
    <div class="cursor-dot" aria-hidden="true"></div>
    <script>
      // custom cursor + card spotlight
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const fine = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

      if (fine && !reduce) {
        const dot = document.querySelector<HTMLElement>('.cursor-dot')!;
        const ring = document.querySelector<HTMLElement>('.cursor-ring')!;
        let tx = -100;
        let ty = -100;
        let rx = -100;
        let ry = -100;

        document.addEventListener(
          'pointermove',
          (e) => {
            tx = e.clientX;
            ty = e.clientY;
            document.body.classList.add('cursor-on');
            dot.style.left = `${tx}px`;
            dot.style.top = `${ty}px`;
            const overLink = (e.target as Element | null)?.closest('a, button');
            document.body.classList.toggle('cursor-hover', !!overLink);
          },
          { passive: true }
        );
        document.addEventListener('pointerleave', () => {
          document.body.classList.remove('cursor-on');
        });
        document.addEventListener('pointerdown', () => {
          document.body.classList.add('cursor-press');
        });
        document.addEventListener('pointerup', () => {
          document.body.classList.remove('cursor-press');
        });

        (function follow() {
          rx += (tx - rx) * 0.18;
          ry += (ty - ry) * 0.18;
          ring.style.left = `${rx}px`;
          ring.style.top = `${ry}px`;
          requestAnimationFrame(follow);
        })();
      }

      // card spotlight coordinates
      document.querySelectorAll<HTMLElement>('.card').forEach((card) => {
        card.addEventListener(
          'pointermove',
          (e) => {
            const r = card.getBoundingClientRect();
            card.style.setProperty('--mx', `${e.clientX - r.left}px`);
            card.style.setProperty('--my', `${e.clientY - r.top}px`);
          },
          { passive: true }
        );
      });
    </script>
    <script>
      // Gentle scroll-end snap: when free scrolling stops near a section
      // boundary, ease it into alignment. Runs only after scrolling settles,
      // so it never fights anchor navigation (which lands exactly aligned).
      const reduceSnap = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduceSnap) {
        // Content-top alignment: scroll-padding (5rem) + scroll-margin
        // (4.5rem - section padding) puts content ~152px from viewport top.
        const CONTENT_ALIGN = 152;
        const THRESHOLD = 170;
        let snapTimer: ReturnType<typeof setTimeout> | undefined;
        let snapping = false;

        window.addEventListener(
          'scroll',
          () => {
            if (snapping) return;
            clearTimeout(snapTimer);
            snapTimer = setTimeout(() => {
              const maxY = document.scrollingElement!.scrollHeight - window.innerHeight;
              // At (or near) the page bottom the user wants the footer —
              // never pull them back up to align a section.
              if (window.scrollY >= maxY - 8) return;
              for (const sec of document.querySelectorAll('main .section')) {
                const padTop = parseFloat(getComputedStyle(sec).paddingTop) || 0;
                const delta = sec.getBoundingClientRect().top - (CONTENT_ALIGN - padTop);
                if (Math.abs(delta) > 4 && Math.abs(delta) < THRESHOLD && window.scrollY + delta <= maxY) {
                  snapping = true;
                  window.scrollBy({ top: delta, behavior: 'smooth' });
                  setTimeout(() => {
                    snapping = false;
                  }, 700);
                  break;
                }
              }
            }, 220);
          },
          { passive: true }
        );
      }

      // scroll reveal
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const targets = document.querySelectorAll('.reveal');
      if (reduceMotion || !('IntersectionObserver' in window)) {
        targets.forEach((el) => el.classList.add('is-visible'));
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
        );
        targets.forEach((el) => observer.observe(el));
      }
    </script>
  </body>
</html>

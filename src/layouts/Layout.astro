---
import '@fontsource-variable/outfit';
import '../styles/global.css';
import InfraBackground from '../components/InfraBackground.astro';

const title = 'infrahats — Production-Grade Infrastructure, Without the Full-Time Hire';
const description =
  'DevOps, SRE, and Solutions Architecture on demand. infrahats designs, deploys, and operates production-grade cloud infrastructure for startups and enterprises — AWS, GCP, Azure, Kubernetes, AI infrastructure, and more.';
const url = 'https://infrahats.com/';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'infrahats',
  url,
  email: 'hello@infrahats.com',
  description,
  knowsAbout: [
    'DevOps',
    'Site Reliability Engineering',
    'Kubernetes',
    'Terraform',
    'AWS',
    'GCP',
    'Azure',
    'AI Infrastructure',
    'Platform Engineering',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="DevOps retainer, SRE consulting, cloud infrastructure, Kubernetes consulting, platform engineering, AI infrastructure, workload migration, fractional DevOps"
    />
    <link rel="canonical" href={url} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${url}og-image.png`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <InfraBackground />
    <slot />
    <div class="cursor-ring" aria-hidden="true">
      <svg viewBox="0 0 40 40">
        <polygon
          points="20,3.5 34.3,11.75 34.3,28.25 20,36.5 5.7,28.25 5.7,11.75"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linejoin="round"></polygon>
      </svg>
    </div>
    <div class="cursor-dot" aria-hidden="true"></div>
    <script>
      // custom cursor + card spotlight
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const fine = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

      if (fine && !reduce) {
        const dot = document.querySelector<HTMLElement>('.cursor-dot')!;
        const ring = document.querySelector<HTMLElement>('.cursor-ring')!;
        let tx = -100;
        let ty = -100;
        let rx = -100;
        let ry = -100;

        document.addEventListener(
          'pointermove',
          (e) => {
            tx = e.clientX;
            ty = e.clientY;
            document.body.classList.add('cursor-on');
            dot.style.left = `${tx}px`;
            dot.style.top = `${ty}px`;
            const overLink = (e.target as Element | null)?.closest('a, button');
            document.body.classList.toggle('cursor-hover', !!overLink);
          },
          { passive: true }
        );
        document.addEventListener('pointerleave', () => {
          document.body.classList.remove('cursor-on');
        });
        document.addEventListener('pointerdown', () => {
          document.body.classList.add('cursor-press');
        });
        document.addEventListener('pointerup', () => {
          document.body.classList.remove('cursor-press');
        });

        (function follow() {
          rx += (tx - rx) * 0.18;
          ry += (ty - ry) * 0.18;
          ring.style.left = `${rx}px`;
          ring.style.top = `${ry}px`;
          requestAnimationFrame(follow);
        })();
      }

      // card spotlight coordinates
      document.querySelectorAll<HTMLElement>('.card').forEach((card) => {
        card.addEventListener(
          'pointermove',
          (e) => {
            const r = card.getBoundingClientRect();
            card.style.setProperty('--mx', `${e.clientX - r.left}px`);
            card.style.setProperty('--my', `${e.clientY - r.top}px`);
          },
          { passive: true }
        );
      });
    </script>
    <script>
      // Gentle scroll-end snap: when free scrolling stops near a section
      // boundary, ease it into alignment. Runs only after scrolling settles,
      // so it never fights anchor navigation (which lands exactly aligned).
      const reduceSnap = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduceSnap) {
        // Content-top alignment: scroll-padding (5rem) + scroll-margin
        // (4.5rem - section padding) puts content ~152px from viewport top.
        const CONTENT_ALIGN = 152;
        const THRESHOLD = 170;
        let snapTimer: ReturnType<typeof setTimeout> | undefined;
        let snapping = false;

        window.addEventListener(
          'scroll',
          () => {
            if (snapping) return;
            clearTimeout(snapTimer);
            snapTimer = setTimeout(() => {
              for (const sec of document.querySelectorAll('main .section')) {
                const padTop = parseFloat(getComputedStyle(sec).paddingTop) || 0;
                const delta = sec.getBoundingClientRect().top - (CONTENT_ALIGN - padTop);
                if (Math.abs(delta) > 4 && Math.abs(delta) < THRESHOLD) {
                  snapping = true;
                  window.scrollBy({ top: delta, behavior: 'smooth' });
                  setTimeout(() => {
                    snapping = false;
                  }, 700);
                  break;
                }
              }
            }, 220);
          },
          { passive: true }
        );
      }

      // scroll reveal
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const targets = document.querySelectorAll('.reveal');
      if (reduceMotion || !('IntersectionObserver' in window)) {
        targets.forEach((el) => el.classList.add('is-visible'));
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
        );
        targets.forEach((el) => observer.observe(el));
      }
    </script>
  </body>
</html>

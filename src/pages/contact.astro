---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { contact } from '../data/content';

const path = '/contact/';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://infrahats.com/' },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: `https://infrahats.com${path}` },
  ],
};
---

<Layout
  title="Contact infrahats | DevOps, SRE & Cloud Infrastructure Consulting"
  description="Book a free discovery call with infrahats for DevOps, SRE, Kubernetes, migrations, AI infrastructure, and platform engineering support."
  path={path}
  schema={[breadcrumbSchema]}
>
  <Nav />
  <main>
    <section class="section container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Contact</span>
      </nav>

      <div class="page-hero">
        <span class="eyebrow">{contact.eyebrow}</span>
        <h1 class="section-title">{contact.title}</h1>
        <p class="section-lead">{contact.lead}</p>
      </div>

      <div class="contact-grid">
        {contact.channels.map((channel) => (
          <a class="card contact-card" href={channel.href} target="_blank" rel="noopener">
            <h2>{channel.label}</h2>
            <p>{channel.value}</p>
          </a>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 2rem;
  }

  .breadcrumbs a {
    color: var(--text-dim);
  }

  .breadcrumbs [aria-current='page'] {
    color: var(--cream);
  }

  .page-hero {
    max-width: 46rem;
    margin-bottom: 2rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .contact-card {
    display: block;
    padding: 1.3rem 1.4rem;
  }

  .contact-card h2 {
    font-size: 1rem;
    margin-bottom: 0.45rem;
  }

  .contact-card p {
    color: var(--text-dim);
  }

  @media (max-width: 860px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { blog, links } from '../data/content';

const path = '/blog/';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://infrahats.com/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `https://infrahats.com${path}` },
  ],
};
---

<Layout
  title="Blog | infrahats"
  description="Practical guidance on platform engineering, DevOps, SRE, Kubernetes, cloud reliability, and infrastructure operations."
  path={path}
  schema={[breadcrumbSchema]}
>
  <Nav />
  <main>
    <section class="section container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Blog</span>
      </nav>

      <div class="page-hero">
        <span class="eyebrow">{blog.eyebrow}</span>
        <h1 class="section-title">{blog.title}</h1>
        <p class="section-lead">{blog.lead}</p>
      </div>

      <div class="post-grid">
        {blog.posts.map((post) => (
          <article class="card post-card">
            <h2>{post.title}</h2>
            <p>{post.summary}</p>
            <a href={`/blog/${post.slug}/`}>Read more →</a>
          </article>
        ))}
      </div>

      <div class="cta-box">
        <a class="btn btn-primary" href={links.calendly} target="_blank" rel="noopener">Book a discovery call</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 2rem;
  }

  .breadcrumbs a {
    color: var(--text-dim);
  }

  .breadcrumbs [aria-current='page'] {
    color: var(--cream);
  }

  .page-hero {
    max-width: 46rem;
    margin-bottom: 2rem;
  }

  .post-grid {
    display: grid;
    gap: 1rem;
  }

  .post-card {
    padding: 1.3rem 1.4rem;
  }

  .post-card h2 {
    font-size: 1.05rem;
    margin-bottom: 0.5rem;
  }

  .post-card p {
    color: var(--text-dim);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .post-card a {
    color: var(--teal-bright);
    font-weight: 600;
  }

  .cta-box {
    margin-top: 1.3rem;
  }
</style>

---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { services } from '../../data/content';

const icons: Record<string, string> = {
  foundation: `<path d="M12 3 3 8l9 5 9-5-9-5Z"/><path d="M3 12l9 5 9-5"/><path d="M3 16l9 5 9-5"/>`,
  support: `<circle cx="12" cy="12" r="3.2"/><path d="M12 2.5v3M12 18.5v3M2.5 12h3M18.5 12h3M5.3 5.3l2.1 2.1M16.6 16.6l2.1 2.1M18.7 5.3l-2.1 2.1M7.4 16.6l-2.1 2.1"/>`,
  deploy: `<path d="M12 19V6"/><path d="m6 12 6-6 6 6"/><path d="M5 21h14"/>`,
  ai: `<rect x="6" y="6" width="12" height="12" rx="2.5"/><path d="M9 2.5V6M15 2.5V6M9 18v3.5M15 18v3.5M2.5 9H6M2.5 15H6M18 9h3.5M18 15h3.5"/><circle cx="12" cy="12" r="1.6"/>`,
  migration: `<path d="M4 8h11"/><path d="m12 4.5 3.5 3.5L12 11.5"/><path d="M20 16H9"/><path d="M12.5 12.5 9 16l3.5 3.5"/>`,
  kubernetes: `<path d="M12 2.8 4 6.8v7L12 21.2l8-7.4v-7l-8-4Z"/><circle cx="12" cy="12" r="3"/>`,
  platform: `<rect x="3" y="4" width="18" height="7" rx="2"/><rect x="3" y="14" width="8" height="6" rx="2"/><rect x="14" y="14" width="7" height="6" rx="2"/>`,
  knowledge: `<path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H20v15.5H6.5A2.5 2.5 0 0 0 4 21V5.5Z"/><path d="M4 18.5A2.5 2.5 0 0 1 6.5 16H20"/>`,
};

const path = '/services/';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://infrahats.com/' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `https://infrahats.com${path}` },
  ],
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: services.items.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `https://infrahats.com/services/${item.slug}/`,
    name: item.title,
  })),
};
---

<Layout
  title="DevOps, SRE & Cloud Infrastructure Services | infrahats"
  description="Eight services covering the full infrastructure lifecycle — foundations, Kubernetes, AI infrastructure, migrations, platform engineering, and ongoing support."
  path={path}
  schema={[breadcrumbSchema, itemListSchema]}
>
  <Nav />
  <main>
    <section class="section container">
      <nav class="breadcrumbs reveal" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Services</span>
      </nav>

      <div class="reveal hub-head">
        <span class="eyebrow">{services.eyebrow}</span>
        <h1 class="section-title">{services.title}</h1>
        <p class="section-lead">{services.lead}</p>
      </div>

      <div class="services-grid">
        {
          services.items.map((item, i) => (
            <a href={`/services/${item.slug}/`} class="card service-card reveal" style={`--reveal-delay: ${(i % 4) * 0.08}s`}>
              <div class="service-icon" aria-hidden="true">
                <svg
                  viewBox="0 0 24 24"
                  width="24"
                  height="24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={icons[item.icon]}
                />
              </div>
              <h2>{item.title}</h2>
              <p>{item.blurb}</p>
              <span class="learn-more">Learn more →</span>
            </a>
          ))
        }
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 2rem;
  }

  .breadcrumbs a {
    color: var(--text-dim);
    transition: color 0.2s;
  }

  .breadcrumbs a:hover {
    color: var(--teal-bright);
  }

  .breadcrumbs [aria-current='page'] {
    color: var(--cream);
  }

  .hub-head {
    max-width: 44rem;
  }

  .services-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.1rem;
  }

  .service-card {
    display: block;
    padding: 1.5rem;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s;
  }

  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.4);
  }

  .service-icon {
    width: 2.9rem;
    height: 2.9rem;
    display: grid;
    place-items: center;
    border-radius: var(--radius-sm);
    color: var(--sage);
    background: rgba(156, 178, 146, 0.09);
    border: 1px solid rgba(156, 178, 146, 0.22);
    margin-bottom: 1.1rem;
    transition: color 0.3s, background-color 0.3s;
  }

  .service-card:hover .service-icon {
    color: var(--teal-bright);
    background: rgba(127, 179, 184, 0.1);
  }

  .service-card h2 {
    font-size: 1.02rem;
    margin-bottom: 0.5rem;
  }

  .service-card p {
    font-size: 0.88rem;
    color: var(--text-dim);
    line-height: 1.6;
  }

  .learn-more {
    display: inline-block;
    margin-top: 0.9rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--teal-bright);
  }

  @media (max-width: 1080px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { about, links } from '../data/content';

const path = '/about/';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://infrahats.com/' },
    { '@type': 'ListItem', position: 2, name: 'About', item: `https://infrahats.com${path}` },
  ],
};
---

<Layout
  title="About infrahats | Senior DevOps, SRE & Cloud Infrastructure Engineers"
  description="We help startups and growing companies deploy and operate production-grade infrastructure without the cost of a full-time engineering team."
  path={path}
  schema={[breadcrumbSchema]}
>
  <Nav />
  <main>
    <section class="section container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">About</span>
      </nav>

      <div class="page-hero">
        <span class="eyebrow">{about.eyebrow}</span>
        <h1 class="section-title">{about.title}</h1>
        <p class="section-lead">{about.lead}</p>
        <a class="btn btn-primary" href={links.calendly} target="_blank" rel="noopener">
          Book a discovery call
        </a>
      </div>

      <div class="cards-grid">
        {about.pillars.map((pillar) => (
          <article class="card">
            <h2>{pillar.title}</h2>
            <p>{pillar.body}</p>
          </article>
        ))}
      </div>

      <div class="stats-grid">
        {about.stats.map((stat) => (
          <div class="stat-card">
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </div>
        ))}
      </div>

      <div class="team-section">
        <h2>Who you'll work with</h2>
        <div class="team-grid">
          {about.team.map((person) => (
            <article class="card team-card">
              <div class="team-avatar" aria-hidden="true">{person.name.split(' ').map((n) => n[0]).join('')}</div>
              <h3>{person.name}</h3>
              <p class="team-role">{person.role}</p>
              <p class="team-bio">{person.bio}</p>
              {person.certifications.length > 0 && (
                <ul class="team-certs">
                  {person.certifications.map((cert) => <li>{cert}</li>)}
                </ul>
              )}
              <a class="team-linkedin" href={person.linkedin} target="_blank" rel="noopener">
                View LinkedIn →
              </a>
            </article>
          ))}
        </div>
      </div>

      <div class="testimonials-section">
        <h2>What clients say</h2>
        <div class="testimonials-grid">
          {about.testimonials.map((t) => (
            <blockquote class="card testimonial-card">
              <p class="testimonial-quote">"{t.quote}"</p>
              <footer class="testimonial-attribution">{t.attribution}</footer>
            </blockquote>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 2rem;
  }

  .breadcrumbs a {
    color: var(--text-dim);
  }

  .breadcrumbs [aria-current='page'] {
    color: var(--cream);
  }

  .page-hero {
    max-width: 46rem;
    margin-bottom: 2.5rem;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .card {
    padding: 1.4rem 1.5rem;
  }

  .card h2 {
    font-size: 1.05rem;
    margin-bottom: 0.55rem;
  }

  .card p {
    color: var(--text-dim);
    line-height: 1.7;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .stat-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 1.1rem 1.2rem;
    background: rgba(255,255,255,0.03);
  }

  .stat-card strong {
    display: block;
    font-size: 1.05rem;
    color: var(--cream);
    margin-bottom: 0.3rem;
  }

  .stat-card span {
    color: var(--text-dim);
  }

  @media (max-width: 860px) {
    .cards-grid,
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }

  .team-section,
  .testimonials-section {
    margin-top: 3.5rem;
  }

  .team-section h2,
  .testimonials-section h2 {
    font-size: 1.3rem;
    margin-bottom: 1.5rem;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.1rem;
  }

  .team-card {
    padding: 1.6rem 1.75rem;
  }

  .team-avatar {
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--sage);
    background: rgba(156, 178, 146, 0.12);
    border: 1px solid rgba(156, 178, 146, 0.3);
    margin-bottom: 1rem;
  }

  .team-card h3 {
    font-size: 1.05rem;
    margin-bottom: 0.3rem;
  }

  .team-role {
    font-size: 0.85rem;
    color: var(--teal-bright);
    font-weight: 600;
    margin-bottom: 0.85rem;
  }

  .team-bio {
    color: var(--text-dim);
    line-height: 1.7;
    font-size: 0.9rem;
    margin-bottom: 0.9rem;
  }

  .team-certs {
    margin: 0 0 1rem;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.35rem;
    color: var(--text-dim);
    font-size: 0.82rem;
  }

  .team-linkedin {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--sage);
  }

  .team-linkedin:hover {
    color: var(--teal-bright);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.1rem;
  }

  .testimonial-card {
    padding: 1.5rem 1.6rem;
    margin: 0;
  }

  .testimonial-quote {
    color: var(--text);
    line-height: 1.7;
    font-size: 0.92rem;
    margin: 0 0 1rem;
  }

  .testimonial-attribution {
    font-size: 0.8rem;
    color: var(--text-faint);
    font-style: normal;
  }

  @media (max-width: 860px) {
    .team-grid,
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
